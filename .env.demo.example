# ─── Base de données ──────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=upstra_demo
DB_USERNAME=upstra
DB_PASSWORD=upstra_demo_password

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TLS=false

# ─── Application ──────────────────────────────────────────────────────────
APP_PORT=3000
# 32 hex chars (AES-128) — CHANGER EN PRODUCTION
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=demo_jwt_secret_change_in_production
JWT_REFRESH_SECRET=demo_jwt_refresh_secret_change_in_production
SESSION_SECRET=demo_session_secret
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d
JWT_2FA_TOKEN_EXPIRATION=5m

# ─── URLs ─────────────────────────────────────────────────────────────────
# Sur VPS : remplacer localhost par le domaine (ex: https://upstra-demo.mondomaine.dev)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000

# ─── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_STRICT_MAX=5
RATE_LIMIT_AUTH_MODERATE_MAX=10
RATE_LIMIT_SENSITIVE_WINDOW_MS=3600000
RATE_LIMIT_SENSITIVE_MAX=3
RATE_LIMIT_API_WINDOW_MS=300000
RATE_LIMIT_API_MAX=100

# ─── Swagger ──────────────────────────────────────────────────────────────
SETUP_KEY=demo_setup_key
SWAGGER_TITLE=Upstra Demo API
SWAGGER_DESCRIPTION=Infrastructure management API - Demo
SWAGGER_VERSION=demo

# ─── GitHub (optionnel — module releases) ─────────────────────────────────
GITHUB_TOKEN=
FRONT_REPO=Upstra/infra-control_front
BACK_REPO=Upstra/infra-control

# ─── Grafana ──────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ─── Mail (optionnel) ─────────────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_SECURE=
MAIL_FROM=
